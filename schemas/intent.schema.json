{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "M5 Resolver Intent (Hardware Context Protocol)",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "capability_query": { "type": "boolean" },
    "registry": {
      "type": "object",
      "properties": {
        "safeguard": { "type": "boolean" },
        "units": {
          "oneOf": [
            { "type": "object", "additionalProperties": { "type": "object" } },
            { "type": "array" }
          ]
        }
      },
      "additionalProperties": true
    },
    "display": {
      "type": "object",
      "properties": {
        "clear": { "type": "boolean" },
        "bg_color": { "type": "integer" },
        "text": {
          "type": "object",
          "properties": {
            "x": { "type": "integer" },
            "y": { "type": "integer" },
            "size": { "type": "integer" },
            "color": { "type": "integer" },
            "payload": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "speaker": {
      "type": "object",
      "properties": {
        "stop": { "type": "boolean" },
        "tone": {
          "type": "object",
          "properties": {
            "frequency": { "type": "number", "minimum": 20, "maximum": 4000 },
            "duration": { "type": "integer", "maximum": 5000 },
            "channel": { "type": "integer" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "power": {
      "type": "object",
      "properties": {
        "led": { "type": "integer", "minimum": 0, "maximum": 255 },
        "off": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
